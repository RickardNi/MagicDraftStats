@page "/decks"
@using MagicDraftStats.Models
@using MagicDraftStats.Services
@inject IDeckImportService DeckImportService
@inject IBGStatsImportService BGStatsService
@inject NavigationManager NavigationManager

<PageTitle>Magic Draft Stats - Decks</PageTitle>

<div class="container mt-2 mt-md-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
        <h1><i class="bi bi-stack me-4 d-none d-md-inline"></i>Decks</h1>
        <div class="text-muted mt-1 mt-md-0">
            Showing @deckRows.Count decks
        </div>
    </div>

    @if (isLoading)
    {
        <div class="alert alert-info">
            <i class="bi bi-arrow-clockwise spin me-2"></i>Loading deck data...
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle"></i>@errorMessage
        </div>
    }
    else if (!deckRows.Any())
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i>No decks found.
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Color Identity</th>
                                <th>Player</th>
                                <th>Date</th>
                                <th class="text-center">Rank</th>
                                <th class="text-center">Plays</th>
                                <th class="text-center">Wins</th>
                                <th class="text-center">Losses</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var deck in deckRows)
                            {
                                <tr style="cursor: pointer;" @onclick="() => OpenDeck(deck.DeckId)">
                                    <td>@deck.ColorIdentity</td>
                                    <td>
                                        @if (deck.PlayerId > 0)
                                        {
                                            <NavLink class="deck-link" href="@Utilities.GetPlayerUrl(deck.PlayerId)" @onclick:stopPropagation="true">@deck.PlayerName</NavLink>
                                        }
                                        else
                                        {
                                            @deck.PlayerName
                                        }
                                    </td>
                                    <td>
                                        @if (deck.Date.HasValue)
                                        {
                                            <span style="white-space: nowrap;">@deck.Date.Value.ToString("yyyy-MM-dd")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="fw-bold @(deck.Rank == 1 ? "text-success-dark" : "text-warning")">@(deck.Rank?.ToString() ?? "-")</span>
                                    </td>
                                    <td class="text-center">0</td>
                                    <td class="text-center"><span class="text-success fw-bold">0</span></td>
                                    <td class="text-center"><span class="text-danger">0</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (!isLoading && validationIssues.Any())
    {
        <div class="card mt-4 border-warning">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-exclamation-triangle me-2"></i>Deck Validation Problems
                    <span class="text-muted ms-2">(@validationIssues.Count)</span>
                </h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Severity</th>
                                <th>File</th>
                                <th>Code</th>
                                <th>Message</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var issue in validationIssues)
                            {
                                <tr>
                                    <td>
                                        <span class="badge @(issue.Severity == DeckValidationSeverity.Error ? "bg-danger" : "bg-warning text-dark")">@issue.Severity</span>
                                    </td>
                                    <td style="white-space: nowrap;">@issue.FilePath</td>
                                    <td><code>@issue.Code</code></td>
                                    <td>@issue.Message</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private List<DeckRow> deckRows = new();
    private List<ValidationIssue> validationIssues = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDecks();
    }

    private async Task LoadDecks()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            validationIssues = new();

            var importResult = await DeckImportService.LoadAndValidateDecksAsync();
            var bgStatsData = await BGStatsService.GetCurrentDataAsync();
            var playerLookup = bgStatsData?.Players?
                .ToDictionary(player => player.Id, player => player.Name)
                ?? new Dictionary<int, string>();

            deckRows = importResult.Items
                .Where(item => item.Deck != null)
                .Select(item => new DeckRow
                {
                    DeckId = Path.GetFileNameWithoutExtension(item.FilePath),
                    Date = item.Deck!.Date,
                    ColorIdentity = FoundationsCardCatalog.GetDeckColorIdentityName(item.Deck!.Cards),
                    PlayerId = item.Deck.PlayerRefId,
                    PlayerName = playerLookup.TryGetValue(item.Deck.PlayerRefId, out var playerName) ? playerName : $"Player #{item.Deck.PlayerRefId}",
                    Rank = item.Deck.Rank
                })
                .OrderByDescending(deck => deck.Date)
                .ThenBy(deck => deck.PlayerName)
                .ToList();

            validationIssues = importResult.Items
                .SelectMany(item => item.ValidationMessages.Select(message => new ValidationIssue
                {
                    FilePath = item.FilePath,
                    Severity = message.Severity,
                    Code = message.Code,
                    Message = message.Message
                }))
                .OrderByDescending(issue => issue.Severity == DeckValidationSeverity.Error)
                .ThenBy(issue => issue.FilePath)
                .ThenBy(issue => issue.Code)
                .ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading deck data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenDeck(string deckId)
    {
        NavigationManager.NavigateTo($"deck/{Uri.EscapeDataString(deckId)}");
    }

    private class DeckRow
    {
        public string DeckId { get; set; } = string.Empty;
        public string ColorIdentity { get; set; } = string.Empty;
        public DateOnly? Date { get; set; }
        public int PlayerId { get; set; }
        public string PlayerName { get; set; } = string.Empty;
        public int? Rank { get; set; }
    }

    private class ValidationIssue
    {
        public string FilePath { get; set; } = string.Empty;
        public DeckValidationSeverity Severity { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
    }
}
