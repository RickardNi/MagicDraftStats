@page "/cards"
@using MagicDraftStats.Components
@using MagicDraftStats.Models
@using MagicDraftStats.Services
@inject IDeckImportService DeckImportService
@inject IScryfallCardService ScryfallCardService
@inject IJSRuntime JSRuntime

<PageTitle>Magic Draft Stats - Cards</PageTitle>

<div class="container mt-2 mt-md-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
        <h1><i class="bi bi-back me-4 d-none d-md-inline"></i>Cards</h1>
        <div class="text-muted mt-1 mt-md-0">
            Showing @cardRows.Count cards across @totalDeckCount decks
        </div>
    </div>

    @if (isLoading)
    {
        <div class="alert alert-info">
            <i class="bi bi-arrow-clockwise spin me-2"></i>Loading card statistics...
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
        </div>
    }
    else if (!cardRows.Any())
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>No cards found.
        </div>
    }
    else
    {
        var filteredRows = GetFilteredRows().ToList();

        <div class="card mb-4">
            <div class="card-header">
                <button class="btn btn-link text-decoration-none p-0 w-100 d-flex align-items-center justify-content-between fw-semibold collapsed"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#cardsFiltersCollapse"
                        aria-expanded="false"
                        aria-controls="cardsFiltersCollapse">
                    <span><i class="bi bi-funnel me-2"></i>Filters</span>
                    <i class="bi bi-chevron-down"></i>
                </button>
            </div>
            <div id="cardsFiltersCollapse" class="collapse">
                <div class="card-body">
                <div class="row g-3">
                    <div class="col-12 col-lg-4">
                        <label class="form-label fw-bold mb-2">Colors</label>
                        <div class="d-flex flex-column gap-1">
                            @foreach (var color in colorFilterOrder)
                            {
                                var checkboxId = $"cards-filter-color-{color}";
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox" id="@checkboxId" checked="@selectedColorFilters.Contains(color)" @onchange="(e) => OnColorFilterChanged(color, e.Value)" />
                                    <label class="form-check-label" for="@checkboxId">@GetColorFilterLabel(color)</label>
                                </div>
                            }
                        </div>
                        <div class="mt-3">
                            <div class="btn-group btn-group-sm" role="group" aria-label="Color filter actions">
                                <button class="btn btn-outline-primary" @onclick="SelectAllColors">Select All</button>
                                <button class="btn btn-outline-secondary" @onclick="ClearAllColors">Clear All</button>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-8">
                        <label class="form-label fw-bold mb-2">Types</label>
                        <div class="row row-cols-1 row-cols-md-2 g-1">
                            @foreach (var type in availableTypeFilters)
                            {
                                var checkboxId = $"cards-filter-type-{type.Replace(" ", "-").ToLowerInvariant()}";
                                <div class="col">
                                    <div class="form-check form-switch mb-0">
                                        <input class="form-check-input" type="checkbox" id="@checkboxId" checked="@selectedTypeFilters.Contains(type)" @onchange="(e) => OnTypeFilterChanged(type, e.Value)" />
                                        <label class="form-check-label" for="@checkboxId">@type</label>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="mt-3">
                            <div class="btn-group btn-group-sm" role="group" aria-label="Type filter actions">
                                <button class="btn btn-outline-primary" @onclick="SelectAllTypes">Select All</button>
                                <button class="btn btn-outline-secondary" @onclick="ClearAllTypes">Clear All</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12 col-md-3">
                        <button class="btn btn-secondary w-100" @onclick="ResetFilters">
                            <i class="bi bi-arrow-clockwise me-1"></i>Reset Filters
                        </button>
                    </div>
                </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead>
                            <tr>
                                <th>
                                    <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(SortColumn.CardName)">
                                        Card
                                        @SortIcon(SortColumn.CardName)
                                    </button>
                                </th>
                                <th>
                                    <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(SortColumn.Type)">
                                        Type
                                        @SortIcon(SortColumn.Type)
                                    </button>
                                </th>
                                <th>
                                    <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(SortColumn.Color)">
                                        Color
                                        @SortIcon(SortColumn.Color)
                                    </button>
                                </th>
                                <th class="text-center">
                                    <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(SortColumn.Decks)" data-bs-toggle="tooltip" data-bs-custom-class="cards-stat-tooltip" data-bs-title="@GetStatTooltip(SortColumn.Decks)">
                                        Decks
                                        @SortIcon(SortColumn.Decks)
                                    </button>
                                </th>
                                <th class="text-center">
                                    <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(SortColumn.PlayedPercent)" data-bs-toggle="tooltip" data-bs-custom-class="cards-stat-tooltip" data-bs-title="@GetStatTooltip(SortColumn.PlayedPercent)">
                                        Played %
                                        @SortIcon(SortColumn.PlayedPercent)
                                    </button>
                                </th>
                                <th class="text-center">
                                    <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(SortColumn.WinnerDecks)" data-bs-toggle="tooltip" data-bs-custom-class="cards-stat-tooltip" data-bs-title="@GetStatTooltip(SortColumn.WinnerDecks)">
                                        Winner Decks
                                        @SortIcon(SortColumn.WinnerDecks)
                                    </button>
                                </th>
                                <th class="text-center">
                                    <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(SortColumn.WinnerDeckPercent)" data-bs-toggle="tooltip" data-bs-custom-class="cards-stat-tooltip" data-bs-title="@GetStatTooltip(SortColumn.WinnerDeckPercent)">
                                        Winner Deck %
                                        @SortIcon(SortColumn.WinnerDeckPercent)
                                    </button>
                                </th>
                                <th class="text-center">
                                    <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(SortColumn.WinnerSharePercent)" data-bs-toggle="tooltip" data-bs-custom-class="cards-stat-tooltip" data-bs-title="@GetStatTooltip(SortColumn.WinnerSharePercent)">
                                        Win Share
                                        @SortIcon(SortColumn.WinnerSharePercent)
                                    </button>
                                </th>
                                <th class="text-center">
                                    <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(SortColumn.AverageRank)" data-bs-toggle="tooltip" data-bs-custom-class="cards-stat-tooltip" data-bs-title="@GetStatTooltip(SortColumn.AverageRank)">
                                        Avg Rank
                                        @SortIcon(SortColumn.AverageRank)
                                    </button>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var card in GetSortedRows(filteredRows))
                            {
                                <tr>
                                    <td>
                                        <span class="fw-semibold" data-preview-url="@card.ImageUrl" data-preview-alt="@card.CardName" onmouseenter="DeckVisualTooltip.show(event, this)" onmousemove="DeckVisualTooltip.move(event, this)" onmouseleave="DeckVisualTooltip.hide()">
                                            @card.CardName
                                        </span>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(card.TypeLine))
                                        {
                                            <span>@card.TypeLine</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (card.ColorSymbols.Count > 0)
                                        {
                                            <div class="d-flex align-items-center gap-1" style="min-width: fit-content;">
                                                @foreach (var symbol in card.ColorSymbols)
                                                {
                                                    <ColorChip ColorKey="@symbol.ColorKey" IsSplash="@symbol.IsSplash" />
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-center">@card.DeckCount</td>
                                    <td class="text-center">@FormatPercent(card.PlayedPercent)</td>
                                    <td class="text-center"><span class="fw-bold text-success-dark">@card.WinnerDeckCount</span></td>
                                    <td class="text-center">@FormatPercent(card.WinnerDeckPercent)</td>
                                    <td class="text-center">@FormatPercent(card.WinnerSharePercent)</td>
                                    <td class="text-center">@FormatAverageRank(card.AverageRank)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private List<CardRow> cardRows = new();
    private int totalDeckCount;
    private int totalWinnerDeckCount;
    private readonly List<string> colorFilterOrder = ["W", "U", "B", "R", "G", "C"];
    private List<string> availableTypeFilters = new();
    private HashSet<string> selectedColorFilters = new(StringComparer.Ordinal);
    private HashSet<string> selectedTypeFilters = new(StringComparer.OrdinalIgnoreCase);
    private SortColumn currentSortColumn = SortColumn.WinnerDeckPercent;
    private bool isAscending = false;

    private static readonly string[] TypeFilterDisplayOrder =
    [
        "Creature",
        "Instant",
        "Sorcery",
        "Artifact",
        "Enchantment",
        "Planeswalker",
        "Land",
        "Basic Land"
    ];

    private enum SortColumn
    {
        CardName,
        Type,
        Color,
        Decks,
        PlayedPercent,
        WinnerDecks,
        WinnerDeckPercent,
        WinnerSharePercent,
        AverageRank
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JSRuntime.InvokeVoidAsync("MagicDraftStatsTooltips.init", "[data-bs-toggle='tooltip']");
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            errorMessage = null;

            var importResult = await DeckImportService.LoadAndValidateDecksAsync();
            var decks = importResult.Items
                .Where(item => item.Deck != null)
                .Select(item => item.Deck!)
                .ToList();

            totalDeckCount = decks.Count;
            totalWinnerDeckCount = decks.Count(deck => deck.Rank == 1);

            var aggregates = new Dictionary<string, CardAggregate>(StringComparer.OrdinalIgnoreCase);

            foreach (var deck in decks)
            {
                var cardsInDeck = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

                foreach (var card in deck.Cards.Where(card => card.Count > 0 && !string.IsNullOrWhiteSpace(card.Name)))
                {
                    var cardName = card.Name.Trim();
                    if (!aggregates.TryGetValue(cardName, out var aggregate))
                    {
                        aggregate = new CardAggregate(cardName);
                        aggregates[cardName] = aggregate;
                    }

                    aggregate.TotalCopies += card.Count;

                    if (cardsInDeck.Add(cardName))
                    {
                        aggregate.DeckCount++;

                        if (deck.Rank == 1)
                        {
                            aggregate.WinnerDeckCount++;
                        }

                        if (deck.Rank.HasValue)
                        {
                            aggregate.RankSum += deck.Rank.Value;
                            aggregate.RankCount++;
                        }
                    }
                }
            }

            var cardsForVisualLookup = aggregates.Keys
                .Select(cardName => new CardEntry { Name = cardName, Count = 1 })
                .ToList();

            var visuals = cardsForVisualLookup.Any()
                ? await ScryfallCardService.GetDeckCardVisualsAsync(cardsForVisualLookup, "fdn")
                : [];

            var visualsByName = visuals.ToDictionary(card => card.Name, StringComparer.OrdinalIgnoreCase);

            cardRows = aggregates.Values
                .Select(aggregate => BuildCardRow(aggregate, visualsByName))
                .OrderByDescending(row => row.DeckCount)
                .ThenBy(row => row.CardName, StringComparer.Ordinal)
                .ToList();

            InitializeFilters();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading card data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private CardRow BuildCardRow(CardAggregate aggregate, Dictionary<string, DeckCardVisual> visualsByName)
    {
        visualsByName.TryGetValue(aggregate.CardName, out var visual);
        FoundationsCardCatalog.TryGetMetadata(aggregate.CardName, out var metadata);

        var colors = visual?.ColorIdentity?.Length > 0
            ? visual.ColorIdentity
            : metadata?.ColorIdentity ?? [];

        var typeLine = metadata is not null && metadata.Types.Length > 0
            ? string.Join(" / ", metadata.Types)
            : "";

        var cardTypes = GetCardTypes(metadata);
        var isBasicLand = cardTypes.Contains("Basic Land", StringComparer.OrdinalIgnoreCase);
        var colorFilterKeys = colors.Length > 0
            ? colors.Distinct(StringComparer.Ordinal).OrderBy(ColorIdentityHelper.GetColorOrder).ToList()
            : ["C"];

        return new CardRow
        {
            CardName = aggregate.CardName,
            TypeLine = typeLine,
            ColorSymbols = colors
                .Distinct(StringComparer.Ordinal)
                .OrderBy(ColorIdentityHelper.GetColorOrder)
                .Select(color => new DeckColorSymbol(color, false))
                .ToList(),
            ColorFilterKeys = colorFilterKeys,
            TypeFilters = cardTypes,
            IsBasicLand = isBasicLand,
            ImageUrl = visual?.ImageUrl ?? $"https://api.scryfall.com/cards/named?exact={Uri.EscapeDataString(aggregate.CardName)}&set=fdn&format=image",
            DeckCount = aggregate.DeckCount,
            PlayedPercent = totalDeckCount > 0 ? (double)aggregate.DeckCount / totalDeckCount : null,
            WinnerDeckCount = aggregate.WinnerDeckCount,
            WinnerDeckPercent = totalWinnerDeckCount > 0 ? (double)aggregate.WinnerDeckCount / totalWinnerDeckCount : null,
            WinnerSharePercent = aggregate.DeckCount > 0 ? (double)aggregate.WinnerDeckCount / aggregate.DeckCount : null,
            AverageRank = aggregate.RankCount > 0 ? (double)aggregate.RankSum / aggregate.RankCount : null
        };
    }

    private void SortBy(SortColumn column)
    {
        if (currentSortColumn == column)
        {
            isAscending = !isAscending;
        }
        else
        {
            currentSortColumn = column;
            isAscending = false;
        }
    }

    private void InitializeFilters()
    {
        availableTypeFilters = cardRows
            .SelectMany(row => row.TypeFilters)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(type => Array.IndexOf(TypeFilterDisplayOrder, type) >= 0 ? Array.IndexOf(TypeFilterDisplayOrder, type) : int.MaxValue)
            .ThenBy(type => type, StringComparer.Ordinal)
            .ToList();

        if (selectedColorFilters.Count == 0)
        {
            selectedColorFilters = colorFilterOrder.ToHashSet(StringComparer.Ordinal);
        }
        else
        {
            selectedColorFilters.IntersectWith(colorFilterOrder);
            if (selectedColorFilters.Count == 0)
            {
                selectedColorFilters = colorFilterOrder.ToHashSet(StringComparer.Ordinal);
            }
        }

        if (selectedTypeFilters.Count == 0)
        {
            selectedTypeFilters = availableTypeFilters
                .Where(type => !type.Equals("Basic Land", StringComparison.OrdinalIgnoreCase))
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
        }
        else
        {
            selectedTypeFilters.IntersectWith(availableTypeFilters);
            if (selectedTypeFilters.Count == 0)
            {
                selectedTypeFilters = availableTypeFilters
                    .Where(type => !type.Equals("Basic Land", StringComparison.OrdinalIgnoreCase))
                    .ToHashSet(StringComparer.OrdinalIgnoreCase);
            }
        }
    }

    private IEnumerable<CardRow> GetFilteredRows()
    {
        return cardRows.Where(row =>
        {
            var matchesColor = selectedColorFilters.Count == 0
                || row.ColorFilterKeys.Any(color => selectedColorFilters.Contains(color));

            var matchesType = selectedTypeFilters.Count == 0
                || row.TypeFilters.Any(type => selectedTypeFilters.Contains(type));

            var basicLandAllowed = !row.IsBasicLand || selectedTypeFilters.Contains("Basic Land");

            return matchesColor && matchesType && basicLandAllowed;
        });
    }

    private IEnumerable<CardRow> GetSortedRows(IEnumerable<CardRow> source)
    {
        var query = currentSortColumn switch
        {
            SortColumn.CardName => isAscending
                ? source.OrderBy(row => row.CardName, StringComparer.Ordinal)
                : source.OrderByDescending(row => row.CardName, StringComparer.Ordinal),
            SortColumn.Type => isAscending
                ? source.OrderBy(row => row.TypeLine, StringComparer.Ordinal)
                : source.OrderByDescending(row => row.TypeLine, StringComparer.Ordinal),
            SortColumn.Color => isAscending
                ? source.OrderBy(row => row.ColorKey)
                : source.OrderByDescending(row => row.ColorKey),
            SortColumn.Decks => isAscending
                ? source.OrderBy(row => row.DeckCount)
                : source.OrderByDescending(row => row.DeckCount),
            SortColumn.PlayedPercent => isAscending
                ? source.OrderBy(row => row.PlayedPercent ?? -1)
                : source.OrderByDescending(row => row.PlayedPercent ?? -1),
            SortColumn.WinnerDecks => isAscending
                ? source.OrderBy(row => row.WinnerDeckCount)
                : source.OrderByDescending(row => row.WinnerDeckCount),
            SortColumn.WinnerDeckPercent => isAscending
                ? source.OrderBy(row => row.WinnerDeckPercent ?? -1)
                : source.OrderByDescending(row => row.WinnerDeckPercent ?? -1),
            SortColumn.WinnerSharePercent => isAscending
                ? source.OrderBy(row => row.WinnerSharePercent ?? -1)
                : source.OrderByDescending(row => row.WinnerSharePercent ?? -1),
            SortColumn.AverageRank => isAscending
                ? source.OrderBy(row => row.AverageRank ?? double.MaxValue)
                : source.OrderByDescending(row => row.AverageRank ?? -1),
            _ => source.OrderByDescending(row => row.DeckCount)
        };

        return query
            .ThenByDescending(row => row.DeckCount)
            .ThenBy(row => row.CardName, StringComparer.Ordinal);
    }

    private void OnColorFilterChanged(string color, object? value)
    {
        var isChecked = value is bool checkedValue && checkedValue;
        if (isChecked)
        {
            selectedColorFilters.Add(color);
        }
        else
        {
            selectedColorFilters.Remove(color);
        }
    }

    private void OnTypeFilterChanged(string type, object? value)
    {
        var isChecked = value is bool checkedValue && checkedValue;
        if (isChecked)
        {
            selectedTypeFilters.Add(type);
        }
        else
        {
            selectedTypeFilters.Remove(type);
        }
    }

    private void SelectAllColors()
    {
        selectedColorFilters = colorFilterOrder.ToHashSet(StringComparer.Ordinal);
    }

    private void ClearAllColors()
    {
        selectedColorFilters.Clear();
    }

    private void SelectAllTypes()
    {
        selectedTypeFilters = availableTypeFilters.ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private void ClearAllTypes()
    {
        selectedTypeFilters.Clear();
    }

    private void ResetFilters()
    {
        selectedColorFilters = colorFilterOrder.ToHashSet(StringComparer.Ordinal);
        selectedTypeFilters = availableTypeFilters
            .Where(type => !type.Equals("Basic Land", StringComparison.OrdinalIgnoreCase))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private static List<string> GetCardTypes(FoundationsCardMetadata? metadata)
    {
        if (metadata is null)
        {
            return [];
        }

        var detectedTypes = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        foreach (var typeGroup in metadata.Types)
        {
            var parts = typeGroup
                .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

            if (parts.Contains("Creature", StringComparer.OrdinalIgnoreCase))
            {
                detectedTypes.Add("Creature");
            }

            if (parts.Contains("Instant", StringComparer.OrdinalIgnoreCase))
            {
                detectedTypes.Add("Instant");
            }

            if (parts.Contains("Sorcery", StringComparer.OrdinalIgnoreCase))
            {
                detectedTypes.Add("Sorcery");
            }

            if (parts.Contains("Artifact", StringComparer.OrdinalIgnoreCase))
            {
                detectedTypes.Add("Artifact");
            }

            if (parts.Contains("Enchantment", StringComparer.OrdinalIgnoreCase))
            {
                detectedTypes.Add("Enchantment");
            }

            if (parts.Contains("Planeswalker", StringComparer.OrdinalIgnoreCase))
            {
                detectedTypes.Add("Planeswalker");
            }

            if (parts.Contains("Land", StringComparer.OrdinalIgnoreCase))
            {
                detectedTypes.Add("Land");
            }

            if (parts.Contains("Basic", StringComparer.OrdinalIgnoreCase)
                && parts.Contains("Land", StringComparer.OrdinalIgnoreCase))
            {
                detectedTypes.Add("Basic Land");
            }
        }

        return detectedTypes
            .OrderBy(type => Array.IndexOf(TypeFilterDisplayOrder, type) >= 0 ? Array.IndexOf(TypeFilterDisplayOrder, type) : int.MaxValue)
            .ThenBy(type => type, StringComparer.Ordinal)
            .ToList();
    }

    private static string GetColorFilterLabel(string color) => color switch
    {
        "W" => "White",
        "U" => "Blue",
        "B" => "Black",
        "R" => "Red",
        "G" => "Green",
        "C" => "Colorless",
        _ => color
    };

    private static string GetStatTooltip(SortColumn column) => column switch
    {
        SortColumn.Decks => "How many decks include this card at least once.\n\nUsefulness: Low-Medium for card quality (mainly sample size/popularity).",
        SortColumn.PlayedPercent => "Decks with card / all decks.\n\nUsefulness: Low-Medium (mostly popularity/availability).",
        SortColumn.WinnerDecks => "How many rank-1 decks include this card.\n\nUsefulness: Low by itself (biased by popularity).",
        SortColumn.WinnerDeckPercent => "Winner decks with card / all winner decks.\n\nUsefulness: Medium (presence in successful decks, still popularity-biased).",
        SortColumn.WinnerSharePercent => "Winner decks with card / decks with card.\nInterpretation: if a deck includes this card, how often that deck is rank-1.\n\nUsefulness: Medium-High (best current single proxy).",
        SortColumn.AverageRank => "Average deck rank where this card appears (1 is best).\n\nUsefulness: Medium (good direction, noisy at small sample sizes).",
        _ => string.Empty
    };

    private MarkupString SortIcon(SortColumn column)
    {
        var iconClass = currentSortColumn == column
            ? (isAscending ? "bi-sort-up" : "bi-sort-down")
            : "bi-sort text-muted";

        return new MarkupString($"<i class=\"bi {iconClass}\"></i>");
    }

    private static string FormatPercent(double? value)
    {
        if (!value.HasValue)
        {
            return "-";
        }

        return Utilities.FormatWinRate(value.Value);
    }

    private static string FormatAverageRank(double? value)
    {
        if (!value.HasValue)
        {
            return "-";
        }

        return value.Value.ToString("F2");
    }

    private sealed class CardAggregate(string cardName)
    {
        public string CardName { get; } = cardName;
        public int DeckCount { get; set; }
        public int WinnerDeckCount { get; set; }
        public int TotalCopies { get; set; }
        public int RankSum { get; set; }
        public int RankCount { get; set; }
    }

    private sealed class CardRow
    {
        public string CardName { get; set; } = string.Empty;
        public string TypeLine { get; set; } = string.Empty;
        public List<DeckColorSymbol> ColorSymbols { get; set; } = new();
        public List<string> ColorFilterKeys { get; set; } = new();
        public List<string> TypeFilters { get; set; } = new();
        public bool IsBasicLand { get; set; }
        public string ImageUrl { get; set; } = string.Empty;
        public int DeckCount { get; set; }
        public int WinnerDeckCount { get; set; }
        public double? PlayedPercent { get; set; }
        public double? WinnerDeckPercent { get; set; }
        public double? WinnerSharePercent { get; set; }
        public double? AverageRank { get; set; }
        public string ColorKey => string.Join(string.Empty, ColorSymbols.Select(symbol => symbol.ColorKey));
    }
}