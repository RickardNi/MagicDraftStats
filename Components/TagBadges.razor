@using MagicDraftStats.Models

@if (Type != BadgeType.None)
{
    <span class="badge @CssClass" aria-label="@Label" title="@Label">
        <i class="bi @Icon"></i>
    </span>
}

@code {
    [Parameter]
    public BadgeType Type { get; set; }

    private string CssClass => Type switch
    {
        BadgeType.MajorTrophy => "bg-warning text-dark tag-badge tag-badge--major-trophy",
        BadgeType.MinorTrophy => "bg-warning text-dark tag-badge tag-badge--minor-trophy",
        _ => ""
    };

    private string Icon => Type switch
    {
        BadgeType.MajorTrophy or BadgeType.MinorTrophy => "bi-trophy-fill",
        _ => ""
    };

    private string Label => Type switch
    {
        BadgeType.MajorTrophy => "Winner of a draft with 4+ players",
        BadgeType.MinorTrophy => "Winner of a draft with 2-3 players",
        _ => ""
    };
}