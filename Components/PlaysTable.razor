@using MagicDraftStats.Models
@using MagicDraftStats.Services
@using System.Text.RegularExpressions

@if (Plays == null || !Plays.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No plays data available. Count: @(Plays?.Count ?? 0)
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th style="white-space: nowrap;">Date</th>
                    <th>Duration</th>
                    <th class="flag-icon-column"></th>
                    <th>Winner</th>
                    <th></th>
                    <th class="flag-icon-column"></th>
                    <th>Loser</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var play in Plays)
                {
                    var winner = play.PlayerScores.FirstOrDefault(p => p.IsWinner);
                    var loser = play.PlayerScores.FirstOrDefault(p => !p.IsWinner);
                    
                    <tr>
                        <td style="white-space: nowrap;">@DateTime.Parse(play.Date).ToString("yyyy-MM-dd")</td>
                        <td>@(play.DurationInMinutes > 0 ? $"{play.DurationInMinutes} min" : "-")</td>
                        <td class="flag-icon-column">
                            @if (winner?.IsFirstPlayer == true)
                            {
                                <i class="bi bi-flag-fill text-warning" title="First Player"></i>
                            }
                        </td>
                        <td>
                            @if (winner != null)
                            {
                                <NavLink class="@($"player-link text-success {GetPlayerWeightClass(play, winner)}")" href="@Utilities.GetPlayerUrl(winner.PlayerRefId)">@winner.PlayerName</NavLink>
                            }
                            else
                            {
                                <span class="text-muted">No winner</span>
                            }
                        </td>
                        <td>
                            @if (winner != null)
                            {
                                var winnerColorSymbols = GetRoleColorSymbols(winner.Deck);

                                @if (winnerColorSymbols.Count > 0)
                                {
                                    <div class="d-flex align-items-center gap-1" style="min-width: fit-content;">
                                        @foreach (var symbol in winnerColorSymbols)
                                        {
                                            <ColorChip ColorKey="@symbol.ColorKey" />
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="flag-icon-column">
                            @if (loser?.IsFirstPlayer == true)
                            {
                                <i class="bi bi-flag-fill text-warning" title="First Player"></i>
                            }
                        </td>
                        <td>
                            @if (loser != null)
                            {
                                <NavLink class="@($"player-link text-danger {GetPlayerWeightClass(play, loser)}")" href="@Utilities.GetPlayerUrl(loser.PlayerRefId)">@loser.PlayerName</NavLink>
                            }
                            else
                            {
                                <span class="text-muted">No loser</span>
                            }
                        </td>
                        <td>
                            @if (loser != null)
                            {
                                var loserColorSymbols = GetRoleColorSymbols(loser.Deck);

                                @if (loserColorSymbols.Count > 0)
                                {
                                    <div class="d-flex align-items-center gap-1" style="min-width: fit-content;">
                                        @foreach (var symbol in loserColorSymbols)
                                        {
                                            <ColorChip ColorKey="@symbol.ColorKey" />
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private static readonly Dictionary<string, string> ColorNameToKey = new(StringComparer.OrdinalIgnoreCase)
    {
        ["White"] = "W",
        ["Blue"] = "U",
        ["Black"] = "B",
        ["Red"] = "R",
        ["Green"] = "G"
    };

    private static readonly Dictionary<string, int> ColorOrder = new(StringComparer.Ordinal)
    {
        ["W"] = 0,
        ["U"] = 1,
        ["B"] = 2,
        ["R"] = 3,
        ["G"] = 4
    };

    [Parameter]
    public List<Play> Plays { get; set; } = new();

    [Parameter]
    public ISet<string>? HighlightScoreKeys { get; set; }

    private string GetPlayerWeightClass(Play play, PlayerScore score)
    {
        if (HighlightScoreKeys is { Count: > 0 })
        {
            return HighlightScoreKeys.Contains(BuildPlayScoreKey(play, score)) ? "fw-bold" : string.Empty;
        }

        return "fw-bold";
    }

    private static string BuildPlayScoreKey(Play play, PlayerScore score)
    {
        return $"{play.Date}|{score.PlayerRefId}|{score.Deck.Trim()}";
    }

    private static List<DeckColorSymbol> GetRoleColorSymbols(string? role)
    {
        if (string.IsNullOrWhiteSpace(role))
        {
            return [];
        }

        var colorKeys = role
            .Split(['／', '/'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(MapRoleTokenToColorKey)
            .Where(key => key is not null)
            .Cast<string>()
            .Distinct(StringComparer.Ordinal)
            .OrderBy(GetColorOrder)
            .ToList();

        if (colorKeys.Count == 0)
        {
            colorKeys = ColorNameToKey
                .Where(entry => Regex.IsMatch(role, $@"\b{Regex.Escape(entry.Key)}\b", RegexOptions.IgnoreCase))
                .Select(entry => entry.Value)
                .Distinct(StringComparer.Ordinal)
                .OrderBy(GetColorOrder)
                .ToList();
        }

        return colorKeys
            .Select(key => new DeckColorSymbol(key, false))
            .ToList();
    }

    private static string? MapRoleTokenToColorKey(string token)
    {
        if (string.IsNullOrWhiteSpace(token))
        {
            return null;
        }

        token = token.Trim();

        if (token.Length == 1)
        {
            var upper = token.ToUpperInvariant();
            if (upper is "W" or "U" or "B" or "R" or "G")
            {
                return upper;
            }
        }

        if (ColorNameToKey.TryGetValue(token, out var colorKey))
        {
            return colorKey;
        }

        return null;
    }

    private static int GetColorOrder(string colorKey)
    {
        return ColorOrder.TryGetValue(colorKey, out var order) ? order : int.MaxValue;
    }
} 