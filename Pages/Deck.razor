@page "/deck/{deckId}"
@using MagicDraftStats.Components
@using MagicDraftStats.Models
@using MagicDraftStats.Services
@inject IDeckImportService DeckImportService
@inject IBGStatsImportService BGStatsService
@inject IDeckStatsService DeckStatsService

<PageTitle>Magic Draft Stats - Deck Details</PageTitle>

<div class="container mt-4">
    <div>
        <h1 class="d-flex align-items-center gap-2 flex-wrap">
            <i class="bi bi-layers-fill me-2"></i>
            <span class="fw-bold">@displayDeckTitle</span>
            @if (deckColorSymbols.Any())
            {
                <span class="d-inline-flex align-items-center gap-1 ms-2 deck-title-mana-symbols">
                    @foreach (var symbol in deckColorSymbols)
                    {
                        <ColorChip ColorKey="@symbol.ColorKey" IsSplash="@symbol.IsSplash" />
                    }
                </span>
            }
        </h1>
    </div>

    @if (isLoading)
    {
        <div class="alert alert-info">
            <i class="bi bi-arrow-clockwise spin me-2"></i>Loading deck details...
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle"></i> @errorMessage
        </div>
    }
    else if (deckFile == null)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> Deck not found.
        </div>
    }
    else
    {
        <div class="mb-4">
            <DeckVisual Cards="@deckFile.Cards" />
        </div>

        @if (HasSideboard)
        {
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-grid-3x3-gap me-2"></i>Sideboard
                    </h5>
                </div>
                <div class="card-body">
                    <DeckVisual Cards="@deckFile.Sideboard" IsSideboard="true" />
                </div>
            </div>
        }

        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-graph-up"></i>Stats
                        </h5>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-5">Plays</dt>
                            <dd class="col-sm-7">@deckPlayCount (<span class="text-success">@deckWinCount W</span>&nbsp;/&nbsp;<span class="text-danger">@deckLossCount L</span>)</dd>
                            <dt class="col-sm-5">Win Rate</dt>
                            <dd class="col-sm-7 @GetWinRateClass(overallWinRate)">@FormatNullableWinRate(overallWinRate)</dd>
                            <dt class="col-sm-5">First Player Win Rate</dt>
                            <dd class="col-sm-7 @GetWinRateClass(firstPlayerWinRate)">@FormatNullableWinRate(firstPlayerWinRate)</dd>
                            <dt class="col-sm-5">Win Rate When Going Second</dt>
                            <dd class="col-sm-7 @GetWinRateClass(goingSecondWinRate)">@FormatNullableWinRate(goingSecondWinRate)</dd>
                            <dt class="col-sm-5">Average Duration</dt>
                            <dd class="col-sm-7">@FormatAverageDuration(averageDurationMinutes)</dd>
                        </dl>
                        <hr class="my-3" />
                        <dl class="row mb-0">
                            <dt class="col-sm-5">Played by</dt>
                            <dd class="col-sm-7">
                                @if (playerId > 0)
                                {
                                    <NavLink class="deck-link" href="@Utilities.GetPlayerUrl(playerId)">@playerName</NavLink>
                                }
                                else
                                {
                                    @playerName
                                }
                            </dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-6 mb-4 mb-md-0">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-1-square"></i>First Player Win Rate</h5>
                    </div>
                    <div class="card-body">
                        @if (deckPlays.Any())
                        {
                            <ApexChart TItem="FirstPlayerStats" Options="@firstPlayerChartOptions">
                                <ApexPointSeries TItem="FirstPlayerStats"
                                                 Items="@firstPlayerStats"
                                                 Name="Plays"
                                                 SeriesType="SeriesType.Pie"
                                                 XValue="@(e => e.Result)"
                                                 YValue="@(e => e.Count)"
                                                 PointColor="e => GetPointColor(e)"
                                                 ShowDataLabels />
                            </ApexChart>
                            <div class="row text-center mt-3">
                                <div class="col-6">
                                    <div class="text-success">
                                        <div class="fw-bold">@winsAsFirstPlayer</div>
                                        <div class="small">Wins</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="text-danger">
                                        <div class="fw-bold">@lossesAsFirstPlayer</div>
                                        <div class="small">Losses</div>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">No plays found</p>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-2-square"></i>Going Second</h5>
                    </div>
                    <div class="card-body">
                        @if (deckPlays.Any())
                        {
                            <ApexChart TItem="FirstPlayerStats" Options="@goingSecondChartOptions">
                                <ApexPointSeries TItem="FirstPlayerStats"
                                                 Items="@goingSecondStats"
                                                 Name="Plays"
                                                 SeriesType="SeriesType.Pie"
                                                 XValue="@(e => e.Result)"
                                                 YValue="@(e => e.Count)"
                                                 PointColor="e => GetPointColor(e)"
                                                 ShowDataLabels />
                            </ApexChart>
                            <div class="row text-center mt-3">
                                <div class="col-6">
                                    <div class="text-success">
                                        <div class="fw-bold">@winsAsNonFirstPlayer</div>
                                        <div class="small">Wins</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="text-danger">
                                        <div class="fw-bold">@lossesAsNonFirstPlayer</div>
                                        <div class="small">Losses</div>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">No plays found</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="bi bi-list-ul"></i>Plays with This Deck</h5>
            </div>
            <div class="card-body">
                @if (deckPlays.Any())
                {
                    <PlaysTable Plays="@deckPlays" HighlightScoreKeys="@highlightedDeckScoreKeys" />
                }
                else
                {
                    <p class="text-muted mb-0">No plays found</p>
                }
            </div>
        </div>

    }

</div>

@code
{
    [Parameter]
    public string deckId { get; set; } = string.Empty;

    private bool isLoading = true;
    private string? errorMessage;
    private DeckFile? deckFile;
    private string displayDeckTitle = "-";
    private List<DeckColorSymbol> deckColorSymbols = new();
    private string playerName = "-";
    private int playerId = 0;
    private HashSet<string> highlightedDeckScoreKeys = new(StringComparer.Ordinal);

    private List<Play> deckPlays = new();
    private ApexChartOptions<FirstPlayerStats> firstPlayerChartOptions = new();
    private List<FirstPlayerStats> firstPlayerStats = new();
    private int deckPlayCount = 0;
    private int deckWinCount = 0;
    private int deckLossCount = 0;
    private double? overallWinRate;
    private double? averageDurationMinutes;
    private double? firstPlayerWinRate;
    private double? goingSecondWinRate;
    private int lossesAsFirstPlayer = 0;
    private int lossesAsNonFirstPlayer = 0;
    private ApexChartOptions<FirstPlayerStats> goingSecondChartOptions = new();
    private List<FirstPlayerStats> goingSecondStats = new();
    private int winsAsFirstPlayer = 0;
    private int winsAsNonFirstPlayer = 0;
    private bool HasSideboard => deckFile?.Sideboard?.Any(card => card.Count > 0) == true;

    protected override async Task OnParametersSetAsync()
    {
        await LoadDeckData();
    }

    private async Task LoadDeckData()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            deckFile = null;
            displayDeckTitle = "-";
            deckColorSymbols = new();
            playerName = "-";
            playerId = 0;
            highlightedDeckScoreKeys.Clear();
            deckPlays.Clear();
            deckPlayCount = 0;
            deckWinCount = 0;
            deckLossCount = 0;
            winsAsFirstPlayer = 0;
            lossesAsFirstPlayer = 0;
            winsAsNonFirstPlayer = 0;
            lossesAsNonFirstPlayer = 0;
            overallWinRate = null;
            averageDurationMinutes = null;
            firstPlayerWinRate = null;
            goingSecondWinRate = null;

            await InvokeAsync(StateHasChanged);

            var decodedDeckId = Uri.UnescapeDataString(deckId ?? string.Empty).Trim();
            var normalizedDeckId = Path.GetFileNameWithoutExtension(decodedDeckId);
            if (string.IsNullOrWhiteSpace(normalizedDeckId))
            {
                normalizedDeckId = decodedDeckId;
            }

            var importResult = await DeckImportService.LoadAndValidateDecksAsync();
            var deckItem = importResult.Items.FirstOrDefault(item =>
                string.Equals(Path.GetFileNameWithoutExtension(item.FilePath), normalizedDeckId, StringComparison.OrdinalIgnoreCase)
                || string.Equals(item.FilePath, decodedDeckId, StringComparison.OrdinalIgnoreCase));

            if (deckItem?.Deck == null)
            {
                return;
            }

            deckFile = deckItem.Deck;
            playerId = deckFile.PlayerRefId;

            var bgStatsData = await BGStatsService.GetCurrentDataAsync();
            playerName = bgStatsData?.Players?.FirstOrDefault(player => player.Id == deckFile.PlayerRefId)?.Name ?? $"Player #{deckFile.PlayerRefId}";
            var deckStats = DeckStatsService.CalculateDeckStats(deckFile, bgStatsData?.Plays ?? []);

            deckPlays = deckStats.MatchedPlays.ToList();
            highlightedDeckScoreKeys = BuildHighlightedDeckScoreKeys(deckFile, deckPlays);
            deckPlayCount = deckStats.Plays;
            deckWinCount = deckStats.Wins;
            deckLossCount = deckStats.Losses;
            overallWinRate = deckPlayCount > 0 ? deckWinCount / (double)deckPlayCount : null;
            averageDurationMinutes = deckPlays.Count > 0 ? deckPlays.Average(play => play.DurationInMinutes) : null;
            winsAsFirstPlayer = deckStats.WinsAsFirstPlayer;
            lossesAsFirstPlayer = deckStats.LossesAsFirstPlayer;
            winsAsNonFirstPlayer = deckStats.WinsAsNonFirstPlayer;
            lossesAsNonFirstPlayer = deckStats.LossesAsNonFirstPlayer;
            firstPlayerWinRate = deckStats.FirstPlayerWinRate;
            goingSecondWinRate = deckStats.GoingSecondWinRate;

            var dateText = deckFile.Date?.ToString("yyyy-MM-dd") ?? Path.GetFileNameWithoutExtension(deckItem.FilePath);
            var colorIdentityName = FoundationsCardCatalog.GetDeckColorIdentityName(deckFile.Cards);
            displayDeckTitle = $"[{dateText}] {colorIdentityName}";
            deckColorSymbols = FoundationsCardCatalog.GetDeckColorIdentitySymbols(deckFile.Cards).ToList();

            firstPlayerStats = new List<FirstPlayerStats>
            {
                new FirstPlayerStats { Result = "Losses", Count = lossesAsFirstPlayer },
                new FirstPlayerStats { Result = "Wins", Count = winsAsFirstPlayer }
            };

            goingSecondStats = new List<FirstPlayerStats>
            {
                new FirstPlayerStats { Result = "Losses", Count = lossesAsNonFirstPlayer },
                new FirstPlayerStats { Result = "Wins", Count = winsAsNonFirstPlayer }
            };

            firstPlayerChartOptions = new ApexChartOptions<FirstPlayerStats>
            {
                Chart = new Chart
                {
                    Type = ChartType.Pie,
                    Height = 300,
                    FontFamily = "Roboto Condensed"
                },
                Legend = new Legend
                {
                    Show = false
                },
                DataLabels = new DataLabels
                {
                    Style = new DataLabelsStyle
                    {
                        FontSize = "14px",
                        FontWeight = "bold"
                    }
                },
                Responsive = new List<Responsive<FirstPlayerStats>>
                {
                    new Responsive<FirstPlayerStats>
                    {
                        Breakpoint = 480,
                        Options = new ApexChartOptions<FirstPlayerStats>
                        {
                            Chart = new Chart { Width = 200, FontFamily = "Roboto Condensed" }
                        }
                    }
                }
            };

            goingSecondChartOptions = new ApexChartOptions<FirstPlayerStats>
            {
                Chart = new Chart
                {
                    Type = ChartType.Pie,
                    Height = 300,
                    FontFamily = "Roboto Condensed"
                },
                Legend = new Legend
                {
                    Show = false
                },
                DataLabels = new DataLabels
                {
                    Style = new DataLabelsStyle
                    {
                        FontSize = "14px",
                        FontWeight = "bold"
                    }
                },
                Responsive = new List<Responsive<FirstPlayerStats>>
                {
                    new Responsive<FirstPlayerStats>
                    {
                        Breakpoint = 480,
                        Options = new ApexChartOptions<FirstPlayerStats>
                        {
                            Chart = new Chart { Width = 200, FontFamily = "Roboto Condensed" }
                        }
                    }
                }
            };
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading deck details: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetPointColor(FirstPlayerStats stats)
    {
        return stats.Result == "Wins" ? "#28a745" : "#dc3545";
    }

    private static string FormatNullableWinRate(double? winRate)
    {
        return winRate.HasValue ? Utilities.FormatWinRate(winRate.Value) : "-";
    }

    private static string GetWinRateClass(double? winRate)
    {
        return winRate.HasValue ? Utilities.GetWinRateColorForDeck(winRate.Value) : "text-muted";
    }

    private static string FormatAverageDuration(double? averageDuration)
    {
        return averageDuration.HasValue ? $"{averageDuration.Value:F1} minutes" : "-";
    }

    private HashSet<string> BuildHighlightedDeckScoreKeys(DeckFile deck, IEnumerable<Play> plays)
    {
        var keys = new HashSet<string>(StringComparer.Ordinal);

        foreach (var play in plays)
        {
            var deckScore = play.PlayerScores.FirstOrDefault(score =>
                score.PlayerRefId == deck.PlayerRefId
                && DeckStatsService.IsRoleMatchForDeck(deck, score.Deck));

            if (deckScore != null)
            {
                keys.Add(BuildPlayScoreKey(play, deckScore));
            }
        }

        return keys;
    }

    private static string BuildPlayScoreKey(Play play, PlayerScore score)
    {
        return $"{play.Date}|{score.PlayerRefId}|{score.Deck.Trim()}";
    }

    public class FirstPlayerStats
    {
        public string Result { get; set; } = string.Empty;
        public int Count { get; set; }
    }
}
