@page "/decks"
@using MagicDraftStats.Models
@using MagicDraftStats.Services
@inject IDeckTableDataService DeckTableDataService

<PageTitle>Magic Draft Stats - Decks</PageTitle>

<div class="container mt-2 mt-md-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
        <h1><i class="bi bi-stack me-4 d-none d-md-inline"></i>Decks</h1>
        <div class="text-muted mt-1 mt-md-0">
            Showing @deckRows.Count decks
        </div>
    </div>

    @if (isLoading)
    {
        <div class="alert alert-info">
            <i class="bi bi-arrow-clockwise spin me-2"></i>Loading deck data...
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle"></i>@errorMessage
        </div>
    }
    else if (!deckRows.Any())
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>No decks found.
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <DecksTable DeckRows="deckRows" />
            </div>
        </div>
    }

    @if (!isLoading && validationIssues.Any())
    {
        <div class="card mt-4 border-warning">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-exclamation-triangle me-2"></i>Deck Validation Problems
                    <span class="text-muted ms-2">(@validationIssues.Count)</span>
                </h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Severity</th>
                                <th>File</th>
                                <th>Code</th>
                                <th>Message</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var issue in validationIssues)
                            {
                                <tr>
                                    <td>
                                        <span class="badge @(issue.Severity == DeckValidationSeverity.Error ? "bg-danger" : "bg-warning text-dark")">@issue.Severity</span>
                                    </td>
                                    <td style="white-space: nowrap;">@issue.FilePath</td>
                                    <td><code>@issue.Code</code></td>
                                    <td>@issue.Message</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private List<DeckTableRow> deckRows = new();
    private List<DeckValidationIssue> validationIssues = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDecks();
    }

    private async Task LoadDecks()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            validationIssues = new();

            var tableData = await DeckTableDataService.LoadAsync();
            deckRows = tableData.DeckRows.ToList();
            validationIssues = tableData.ValidationIssues.ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading deck data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
