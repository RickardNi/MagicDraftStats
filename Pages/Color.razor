@page "/color/{urlDeckName}"
@using MagicDraftStats.Models
@using MagicDraftStats.Services
@using MagicDraftStats.Components
@using System.Web
@inject IBGStatsImportService BGStatsService
@inject IGlobalFilterService GlobalFilterService

<PageTitle>Magic Draft Stats - Color Details</PageTitle>

<div class="container mt-4">
    <div>
        <h1 class="d-flex align-items-center gap-2 flex-wrap">
            <i class="bi bi-palette-fill me-2"></i>
            <span class="fw-bold">@displayColorTitle</span>
            @if (colorIdentitySymbols.Any())
            {
                <span class="d-inline-flex align-items-center gap-1 ms-2 deck-title-mana-symbols">
                    @foreach (var symbol in colorIdentitySymbols)
                    {
                        <ColorChip ColorKey="@symbol.ColorKey" IsSplash="@symbol.IsSplash" />
                    }
                </span>
            }
        </h1>
    </div>

    @if (isLoading)
    {
        <div class="alert alert-info">
            <i class="bi bi-arrow-clockwise spin me-2"></i>Loading color details...
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle"></i> @errorMessage
        </div>
    }
    else if (deckStats == null)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> Color not found.
        </div>
    }
    else
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-graph-up"></i>Stats
                        </h5>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-5">Plays</dt>
                            <dd class="col-sm-7">@deckStats.TotalPlays (<span class="text-success">@deckStats.Wins W</span>&nbsp;/&nbsp;<span class="text-danger">@deckStats.Losses L</span>)</dd>
                            <dt class="col-sm-5">Win Rate</dt>
                            <dd class="col-sm-7 @GetWinRateClass(deckStats.WinRate)">@FormatNullableWinRate(deckStats.WinRate)</dd>
                            <dt class="col-sm-5">First Player Win Rate</dt>
                            <dd class="col-sm-7 @GetWinRateClass(firstPlayerWinRate)">@FormatNullableWinRate(firstPlayerWinRate)</dd>
                            <dt class="col-sm-5">Win Rate When Going Second</dt>
                            <dd class="col-sm-7 @GetWinRateClass(goingSecondWinRate)">@FormatNullableWinRate(goingSecondWinRate)</dd>
                            <dt class="col-sm-5">Average Duration</dt>
                            <dd class="col-sm-7">@FormatAverageDuration(averageDuration)</dd>
                        </dl>
                        <hr class="my-3" />
                        <dl class="row mb-0">
                            @{ var mostPlayedPlayer = GetMostPlayedByPlayer(); }
                            <dt class="col-sm-5">Most Played By</dt>
                            <dd class="col-sm-7">
                                @if (mostPlayedPlayer is not null)
                                {
                                    @if (mostPlayedPlayer.PlayerId > 0)
                                    {
                                        <NavLink class="deck-link" href="@Utilities.GetPlayerUrl(mostPlayedPlayer.PlayerId)">@mostPlayedPlayer.PlayerName</NavLink>
                                    }
                                    else
                                    {
                                        @mostPlayedPlayer.PlayerName
                                    }
                                    <span class="text-muted">&nbsp;(@mostPlayedPlayer.Plays plays)</span>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </dd>

                            @{ var mostSuccessfulPlayer = GetMostSuccessfulPlayer(); }
                            <dt class="col-sm-5">Most Successfully Played By</dt>
                            <dd class="col-sm-7">
                                @if (mostSuccessfulPlayer is not null)
                                {
                                    @if (mostSuccessfulPlayer.PlayerId > 0)
                                    {
                                        <NavLink class="deck-link" href="@Utilities.GetPlayerUrl(mostSuccessfulPlayer.PlayerId)">@mostSuccessfulPlayer.PlayerName</NavLink>
                                    }
                                    else
                                    {
                                        @mostSuccessfulPlayer.PlayerName
                                    }
                                    <span class="@GetWinRateClass(mostSuccessfulPlayer.WinRate)">&nbsp;(@Utilities.FormatWinRate(mostSuccessfulPlayer.WinRate))</span>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </dd>

                            @{ var leastSuccessfulPlayer = GetLeastSuccessfulPlayer(); }
                            <dt class="col-sm-5">Least Successfully Played By</dt>
                            <dd class="col-sm-7">
                                @if (leastSuccessfulPlayer is not null)
                                {
                                    @if (leastSuccessfulPlayer.PlayerId > 0)
                                    {
                                        <NavLink class="deck-link" href="@Utilities.GetPlayerUrl(leastSuccessfulPlayer.PlayerId)">@leastSuccessfulPlayer.PlayerName</NavLink>
                                    }
                                    else
                                    {
                                        @leastSuccessfulPlayer.PlayerName
                                    }
                                    <span class="@GetWinRateClass(leastSuccessfulPlayer.WinRate)">&nbsp;(@Utilities.FormatWinRate(leastSuccessfulPlayer.WinRate))</span>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-6 mb-4 mb-md-0">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-1-square"></i>First Player Win Rate</h5>
                    </div>
                    <div class="card-body">
                        @if (deckPlays.Any())
                        {
                            <ApexChart TItem="FirstPlayerStats" Options="@firstPlayerChartOptions">
                                <ApexPointSeries TItem="FirstPlayerStats"
                                                 Items="@firstPlayerStats"
                                                 Name="Plays"
                                                 SeriesType="SeriesType.Pie"
                                                 XValue="@(e => e.Result)"
                                                 YValue="@(e => e.Count)"
                                                 PointColor="e => GetPointColor(e)"
                                                 ShowDataLabels />
                            </ApexChart>
                            <div class="row text-center mt-3">
                                <div class="col-6">
                                    <div class="text-success">
                                        <div class="fw-bold">@winsAsFirstPlayer</div>
                                        <div class="small">Wins</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="text-danger">
                                        <div class="fw-bold">@lossesAsFirstPlayer</div>
                                        <div class="small">Losses</div>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">No plays found</p>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-2-square"></i>Going Second</h5>
                    </div>
                    <div class="card-body">
                        @if (deckPlays.Any())
                        {
                            <ApexChart TItem="FirstPlayerStats" Options="@goingSecondChartOptions">
                                <ApexPointSeries TItem="FirstPlayerStats"
                                                 Items="@goingSecondStats"
                                                 Name="Plays"
                                                 SeriesType="SeriesType.Pie"
                                                 XValue="@(e => e.Result)"
                                                 YValue="@(e => e.Count)"
                                                 PointColor="e => GetPointColor(e)"
                                                 ShowDataLabels />
                            </ApexChart>
                            <div class="row text-center mt-3">
                                <div class="col-6">
                                    <div class="text-success">
                                        <div class="fw-bold">@winsAsNonFirstPlayer</div>
                                        <div class="small">Wins</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="text-danger">
                                        <div class="fw-bold">@lossesAsNonFirstPlayer</div>
                                        <div class="small">Losses</div>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">No plays found</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-arrow-left-right"></i>Matchups
                </h5>
            </div>
            <div class="card-body">
                @if (matchupStats.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>
                                        <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(MatchupSortColumn.OpponentDeck)">
                                            Colors
                                            @if (currentSortColumn == MatchupSortColumn.OpponentDeck)
                                            {
                                                <i class="bi @(isAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-sort text-muted"></i>
                                            }
                                        </button>
                                    </th>
                                    <th></th>
                                    <th class="text-center">
                                        <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(MatchupSortColumn.Plays)">
                                            Plays
                                            @if (currentSortColumn == MatchupSortColumn.Plays)
                                            {
                                                <i class="bi @(isAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-sort text-muted"></i>
                                            }
                                        </button>
                                    </th>
                                    <th class="text-center">
                                        <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(MatchupSortColumn.Wins)">
                                            Wins
                                            @if (currentSortColumn == MatchupSortColumn.Wins)
                                            {
                                                <i class="bi @(isAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-sort text-muted"></i>
                                            }
                                        </button>
                                    </th>
                                    <th class="text-center">
                                        <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(MatchupSortColumn.Losses)">
                                            Losses
                                            @if (currentSortColumn == MatchupSortColumn.Losses)
                                            {
                                                <i class="bi @(isAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-sort text-muted"></i>
                                            }
                                        </button>
                                    </th>
                                    <th class="text-center">
                                        <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(MatchupSortColumn.WinRate)">
                                            Win Rate
                                            @if (currentSortColumn == MatchupSortColumn.WinRate)
                                            {
                                                <i class="bi @(isAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-sort text-muted"></i>
                                            }
                                        </button>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var vs in GetSortedMatchupStats())
                                {
                                    <tr>
                                        <td>
                                            <NavLink class="deck-link" href="@Utilities.GetDeckUrl(vs.OpponentLinkDeck)">@vs.OpponentDeckName</NavLink>
                                        </td>
                                        <td>
                                            @if (vs.OpponentColorSymbols.Count > 0)
                                            {
                                                <div class="d-flex align-items-center gap-1" style="min-width: fit-content;">
                                                    @foreach (var symbol in vs.OpponentColorSymbols)
                                                    {
                                                        <ColorChip ColorKey="@symbol.ColorKey" IsSplash="@symbol.IsSplash" />
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td class="text-center">@vs.Plays</td>
                                        <td class="text-center text-success">@vs.Wins</td>
                                        <td class="text-center text-danger">@vs.Losses</td>
                                        <td class="text-center fw-bold @(Utilities.GetWinRateColorForDeck(vs.WinRate))">@Utilities.FormatWinRate(vs.WinRate)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info">No plays against other decks found.</div>
                }
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-people-fill"></i>Played By
                </h5>
            </div>
            <div class="card-body">
                @if (playerStats.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>
                                        <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortByPlayer(PlayerSortColumn.Player)">
                                            Player
                                            @if (currentPlayerSortColumn == PlayerSortColumn.Player)
                                            {
                                                <i class="bi @(isPlayerSortAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-sort text-muted"></i>
                                            }
                                        </button>
                                    </th>
                                    <th class="text-center">
                                        <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortByPlayer(PlayerSortColumn.Plays)">
                                            Plays
                                            @if (currentPlayerSortColumn == PlayerSortColumn.Plays)
                                            {
                                                <i class="bi @(isPlayerSortAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-sort text-muted"></i>
                                            }
                                        </button>
                                    </th>
                                    <th class="text-center">
                                        <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortByPlayer(PlayerSortColumn.Wins)">
                                            Wins
                                            @if (currentPlayerSortColumn == PlayerSortColumn.Wins)
                                            {
                                                <i class="bi @(isPlayerSortAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-sort text-muted"></i>
                                            }
                                        </button>
                                    </th>
                                    <th class="text-center">
                                        <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortByPlayer(PlayerSortColumn.Losses)">
                                            Losses
                                            @if (currentPlayerSortColumn == PlayerSortColumn.Losses)
                                            {
                                                <i class="bi @(isPlayerSortAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-sort text-muted"></i>
                                            }
                                        </button>
                                    </th>
                                    <th class="text-center">
                                        <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortByPlayer(PlayerSortColumn.WinRate)">
                                            Win Rate
                                            @if (currentPlayerSortColumn == PlayerSortColumn.WinRate)
                                            {
                                                <i class="bi @(isPlayerSortAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-sort text-muted"></i>
                                            }
                                        </button>
                                    </th>
                                    <th class="text-center">
                                        <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortByPlayer(PlayerSortColumn.Duration)">
                                            Avg Duration
                                            @if (currentPlayerSortColumn == PlayerSortColumn.Duration)
                                            {
                                                <i class="bi @(isPlayerSortAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-sort text-muted"></i>
                                            }
                                        </button>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ps in GetSortedPlayerStats())
                                {
                                    <tr>
                                        <td>
                                            @if (ps.PlayerId > 0)
                                            {
                                                <NavLink class="deck-link" href="@Utilities.GetPlayerUrl(ps.PlayerId)">@ps.PlayerName</NavLink>
                                            }
                                            else
                                            {
                                                @ps.PlayerName
                                            }
                                        </td>
                                        <td class="text-center">@ps.Plays</td>
                                        <td class="text-center text-success">@ps.Wins</td>
                                        <td class="text-center text-danger">@ps.Losses</td>
                                        <td class="text-center fw-bold @(Utilities.GetWinRateColorForPlayer(ps.WinRate))">@Utilities.FormatWinRate(ps.WinRate)</td>
                                        <td class="text-center">@(ps.AverageDuration > 0 ? $"{ps.AverageDuration:F1} min" : "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info">No player data found for this deck.</div>
                }
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="bi bi-list-ul"></i>Plays</h5>
            </div>
            <div class="card-body">
                @if (deckPlays.Any())
                {
                    <PlaysTable Plays="@deckPlays" HighlightScoreKeys="@highlightedColorScoreKeys" />
                }
                else
                {
                    <p class="text-muted mb-0">No plays found</p>
                }
            </div>
        </div>
    }

</div>

@code
{
    [Parameter]
    public string urlDeckName { get; set; } = string.Empty;

    private bool isLoading = true;
    private string? errorMessage;
    private string displayColorTitle = "-";
    private List<DeckColorSymbol> colorIdentitySymbols = new();
    private DeckStats? deckStats;
    private double? averageDuration;
    private List<MatchupStats> matchupStats = new();
    private List<Play> deckPlays = new();
    private HashSet<string> highlightedColorScoreKeys = new(StringComparer.Ordinal);
    private List<PlayerStats> playerStats = new();
    private ApexChartOptions<FirstPlayerStats> firstPlayerChartOptions = new();
    private List<FirstPlayerStats> firstPlayerStats = new();
    private int lossesAsFirstPlayer = 0;
    private int lossesAsNonFirstPlayer = 0;
    private ApexChartOptions<FirstPlayerStats> goingSecondChartOptions = new();
    private List<FirstPlayerStats> goingSecondStats = new();
    private int winsAsFirstPlayer = 0;
    private int winsAsNonFirstPlayer = 0;
    private int playsAsFirstPlayer = 0;
    private int playsAsNonFirstPlayer = 0;
    private double? firstPlayerWinRate;
    private double? goingSecondWinRate;

    private MatchupSortColumn currentSortColumn = MatchupSortColumn.Plays;
    private bool isAscending = false;

    private PlayerSortColumn currentPlayerSortColumn = PlayerSortColumn.Plays;
    private bool isPlayerSortAscending = false;

    protected override void OnInitialized()
    {
        GlobalFilterService.OnFilterChanged += OnFilterChanged;
    }

    public void Dispose()
    {
        GlobalFilterService.OnFilterChanged -= OnFilterChanged;
    }

    private async void OnFilterChanged()
    {
        await InvokeAsync(async () =>
        {
            await LoadDeckData();
            StateHasChanged();
        });
    }

    private async Task LoadDeckData()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            displayColorTitle = "-";
            colorIdentitySymbols = new();
            deckStats = null;
            matchupStats.Clear();
            averageDuration = null;
            deckPlays.Clear();
            highlightedColorScoreKeys.Clear();
            playerStats.Clear();
            firstPlayerStats.Clear();
            goingSecondStats.Clear();
            winsAsFirstPlayer = 0;
            winsAsNonFirstPlayer = 0;
            lossesAsFirstPlayer = 0;
            lossesAsNonFirstPlayer = 0;
            playsAsFirstPlayer = 0;
            playsAsNonFirstPlayer = 0;
            firstPlayerWinRate = null;
            goingSecondWinRate = null;

            var deckName = HttpUtility.UrlDecode(urlDeckName ?? string.Empty).Trim();
            var targetColorKeys = ColorIdentityHelper.GetRoleColorIdentityKeys(deckName);
            displayColorTitle = ColorIdentityHelper.GetColorIdentityName(targetColorKeys);
            colorIdentitySymbols = targetColorKeys.Select(color => new DeckColorSymbol(color, false)).ToList();

            var plays = await BGStatsService.GetMagicPlaysAsync(GlobalFilterService.SelectedVariants);
            var matchedScores = plays
                .SelectMany(play => play.PlayerScores.Select(score => new MatchedColorScore(
                    play,
                    score,
                    ColorIdentityHelper.GetRoleColorIdentityKeys(score.Deck))))
                .Where(entry => IncludesTargetColor(entry.ColorIdentityKeys, targetColorKeys))
                .ToList();

            if (!matchedScores.Any())
            {
                return;
            }

            deckPlays = matchedScores
                .Select(entry => entry.Play)
                .Distinct()
                .OrderByDescending(GetPlayDateSortKey)
                .ToList();

            highlightedColorScoreKeys = matchedScores
                .Select(entry => BuildPlayScoreKey(entry.Play, entry.Score))
                .ToHashSet(StringComparer.Ordinal);

            var allScores = matchedScores
                .Select(entry => entry.Score)
                .ToList();
            var totalPlays = allScores.Count;
            var wins = allScores.Count(ps => ps.IsWinner);
            var losses = allScores.Count(ps => !ps.IsWinner);
            var winRate = totalPlays > 0 ? (double)wins / totalPlays : 0;
            averageDuration = deckPlays.Any() ? deckPlays.Average(p => p.DurationInMinutes) : null;

            deckStats = new DeckStats
            {
                DeckName = displayColorTitle,
                TotalPlays = totalPlays,
                Wins = wins,
                Losses = losses,
                WinRate = winRate
            };

            winsAsFirstPlayer = allScores.Count(score => score.IsWinner && score.IsFirstPlayer);
            lossesAsFirstPlayer = allScores.Count(score => !score.IsWinner && score.IsFirstPlayer);
            winsAsNonFirstPlayer = allScores.Count(score => score.IsWinner && !score.IsFirstPlayer);
            lossesAsNonFirstPlayer = allScores.Count(score => !score.IsWinner && !score.IsFirstPlayer);
            playsAsFirstPlayer = allScores.Count(score => score.IsFirstPlayer);
            playsAsNonFirstPlayer = allScores.Count(score => !score.IsFirstPlayer);
            firstPlayerWinRate = playsAsFirstPlayer > 0 ? winsAsFirstPlayer / (double)playsAsFirstPlayer : null;
            goingSecondWinRate = playsAsNonFirstPlayer > 0 ? winsAsNonFirstPlayer / (double)playsAsNonFirstPlayer : null;
            
            firstPlayerStats = new List<FirstPlayerStats>
            {
                new FirstPlayerStats { Result = "Losses", Count = lossesAsFirstPlayer },
                new FirstPlayerStats { Result = "Wins", Count = winsAsFirstPlayer }
            };
            
            goingSecondStats = new List<FirstPlayerStats>
            {
                new FirstPlayerStats { Result = "Losses", Count = lossesAsNonFirstPlayer },
                new FirstPlayerStats { Result = "Wins", Count = winsAsNonFirstPlayer }
            };
            
            firstPlayerChartOptions = new ApexChartOptions<FirstPlayerStats>
            {
                Chart = new Chart
                {
                    Type = ChartType.Pie,
                    Height = 300,
                    FontFamily = "Roboto Condensed"
                },
                Legend = new Legend
                {
                    Show = false
                },
                DataLabels = new DataLabels
                {
                    Style = new DataLabelsStyle
                    {
                        FontSize = "14px",
                        FontWeight = "bold"
                    }
                },
                Responsive = new List<Responsive<FirstPlayerStats>>
                {
                    new Responsive<FirstPlayerStats>
                    {
                        Breakpoint = 480,
                        Options = new ApexChartOptions<FirstPlayerStats>
                        {
                            Chart = new Chart { Width = 200, FontFamily = "Roboto Condensed" }
                        }
                    }
                }
            };
            
            goingSecondChartOptions = new ApexChartOptions<FirstPlayerStats>
            {
                Chart = new Chart
                {
                    Type = ChartType.Pie,
                    Height = 300,
                    FontFamily = "Roboto Condensed"
                },
                Legend = new Legend
                {
                    Show = false
                },
                DataLabels = new DataLabels
                {
                    Style = new DataLabelsStyle
                    {
                        FontSize = "14px",
                        FontWeight = "bold"
                    }
                },
                Responsive = new List<Responsive<FirstPlayerStats>>
                {
                    new Responsive<FirstPlayerStats>
                    {
                        Breakpoint = 480,
                        Options = new ApexChartOptions<FirstPlayerStats>
                        {
                            Chart = new Chart { Width = 200, FontFamily = "Roboto Condensed" }
                        }
                    }
                }
            };

            // Calculate win rate vs other decks
            var matchupGroups = new Dictionary<string, (string OpponentDeckName, string OpponentLinkDeck, List<DeckColorSymbol> OpponentColorSymbols, int Plays, int Wins, int Losses)>();
            foreach (var playGroup in matchedScores.GroupBy(entry => entry.Play))
            {
                var matchingScores = playGroup.Select(entry => entry.Score).ToList();
                var opponentScores = playGroup
                    .Key
                    .PlayerScores
                    .Where(score => !matchingScores.Contains(score))
                    .ToList();

                foreach (var thisScore in matchingScores)
                {
                    foreach (var opp in opponentScores)
                    {
                        var opponentColorKeys = ColorIdentityHelper.GetRoleColorIdentityKeys(opp.Deck);
                        var opponentIdentityKey = BuildColorIdentityKey(opponentColorKeys);

                        if (!matchupGroups.TryGetValue(opponentIdentityKey, out var matchupGroup))
                        {
                            matchupGroup = (
                                ColorIdentityHelper.GetColorIdentityName(opponentColorKeys),
                                opp.Deck,
                                opponentColorKeys.Select(color => new DeckColorSymbol(color, false)).ToList(),
                                0,
                                0,
                                0);
                        }

                        matchupGroup.Plays++;
                        matchupGroup.Wins += thisScore.IsWinner ? 1 : 0;
                        matchupGroup.Losses += !thisScore.IsWinner ? 1 : 0;

                        matchupGroups[opponentIdentityKey] = matchupGroup;
                    }
                }
            }
            matchupStats = matchupGroups.Select(kvp => new MatchupStats
            {
                OpponentDeckName = kvp.Value.OpponentDeckName,
                OpponentLinkDeck = kvp.Value.OpponentLinkDeck,
                OpponentColorSymbols = kvp.Value.OpponentColorSymbols,
                Plays = kvp.Value.Plays,
                Wins = kvp.Value.Wins,
                Losses = kvp.Value.Losses,
                WinRate = kvp.Value.Plays > 0 ? (double)kvp.Value.Wins / kvp.Value.Plays : 0
            }).ToList();

            // Calculate player stats for this deck
            var playerGroups = new Dictionary<int, (string PlayerName, int Plays, int Wins, int Losses, List<double> Durations)>();
            foreach (var entry in matchedScores)
            {
                var playerName = entry.Score.PlayerName;
                var playerId = entry.Score.PlayerRefId;
                if (playerId <= 0 && string.IsNullOrEmpty(playerName))
                    continue;

                if (!playerGroups.TryGetValue(playerId, out var playerGroup))
                {
                    playerGroup = (playerName, 0, 0, 0, new List<double>());
                }

                var resolvedPlayerName = string.IsNullOrWhiteSpace(playerName) ? playerGroup.PlayerName : playerName;

                var numberOfPlays = playerGroup.Plays + 1;
                var playerWins = playerGroup.Wins + (entry.Score.IsWinner ? 1 : 0);
                var playerLosses = playerGroup.Losses + (entry.Score.IsWinner ? 0 : 1);
                var durations = playerGroup.Durations;
                durations.Add(entry.Play.DurationInMinutes);

                playerGroups[playerId] = (resolvedPlayerName, numberOfPlays, playerWins, playerLosses, durations);
            }

            playerStats = playerGroups.Select(kvp => new PlayerStats
            {
                PlayerId = kvp.Key,
                PlayerName = string.IsNullOrWhiteSpace(kvp.Value.PlayerName) ? $"Player #{kvp.Key}" : kvp.Value.PlayerName,
                Plays = kvp.Value.Plays,
                Wins = kvp.Value.Wins,
                Losses = kvp.Value.Losses,
                WinRate = kvp.Value.Plays > 0 ? (double)kvp.Value.Wins / kvp.Value.Plays : 0,
                AverageDuration = kvp.Value.Durations.Any() ? kvp.Value.Durations.Average() : 0
            }).ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading deck details: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }



    private string GetPointColor(FirstPlayerStats stats)
    {
        return stats.Result == "Wins" ? "#28a745" : "#dc3545";
    }

    private static bool IncludesTargetColor(IReadOnlyList<string> actualColors, IReadOnlyList<string> targetColors)
    {
        if (targetColors.Count == 0)
        {
            return actualColors.Count == 0;
        }

        if (actualColors.Count != targetColors.Count)
        {
            return false;
        }

        return actualColors.SequenceEqual(targetColors, StringComparer.Ordinal);
    }

    private static string BuildColorIdentityKey(IReadOnlyList<string> colorIdentityKeys)
    {
        return colorIdentityKeys.Count == 0 ? "Colorless" : string.Concat(colorIdentityKeys);
    }

    private static string BuildPlayScoreKey(Play play, PlayerScore score)
    {
        return $"{play.Date}|{score.PlayerRefId}|{score.Deck.Trim()}";
    }

    private static string GetWinRateClass(double? winRate)
    {
        return winRate.HasValue ? Utilities.GetWinRateColorForDeck(winRate.Value) : "text-muted";
    }

    private static string FormatNullableWinRate(double? winRate)
    {
        return winRate.HasValue ? Utilities.FormatWinRate(winRate.Value) : "-";
    }

    private static string FormatAverageDuration(double? duration)
    {
        return duration.HasValue && duration.Value > 0 ? $"{duration.Value:F1} min" : "-";
    }

    private static DateTime GetPlayDateSortKey(Play play)
    {
        return DateTime.TryParse(play.Date, out var parsedDate) ? parsedDate : DateTime.MinValue;
    }

    private PlayerStats? GetMostPlayedByPlayer()
    {
        return playerStats
            .OrderByDescending(p => p.Plays)
            .ThenBy(p => p.PlayerName, StringComparer.OrdinalIgnoreCase)
            .FirstOrDefault();
    }

    private PlayerStats? GetMostSuccessfulPlayer()
    {
        return playerStats
            .OrderByDescending(p => p.WinRate)
            .ThenByDescending(p => p.Plays)
            .ThenBy(p => p.PlayerName, StringComparer.OrdinalIgnoreCase)
            .FirstOrDefault();
    }

    private PlayerStats? GetLeastSuccessfulPlayer()
    {
        return playerStats
            .OrderBy(p => p.WinRate)
            .ThenByDescending(p => p.Plays)
            .ThenBy(p => p.PlayerName, StringComparer.OrdinalIgnoreCase)
            .FirstOrDefault();
    }

    private enum MatchupSortColumn
    {
        OpponentDeck,
        Plays,
        Wins,
        Losses,
        WinRate
    }

    private enum PlayerSortColumn
    {
        Player,
        Plays,
        Wins,
        Losses,
        WinRate,
        Duration
    }

    private void SortBy(MatchupSortColumn column)
    {
        if (column == currentSortColumn)
        {
            isAscending = !isAscending;
        }
        else
        {
            currentSortColumn = column;
            isAscending = false;
        }
    }

    private void SortByPlayer(PlayerSortColumn column)
    {
        if (column == currentPlayerSortColumn)
        {
            isPlayerSortAscending = !isPlayerSortAscending;
        }
        else
        {
            currentPlayerSortColumn = column;
            isPlayerSortAscending = false;
        }
    }

    private IEnumerable<MatchupStats> GetSortedMatchupStats()
    {
        IEnumerable<MatchupStats> query = matchupStats;
        switch (currentSortColumn)
        {
            case MatchupSortColumn.OpponentDeck:
                query = isAscending ? query.OrderBy(m => m.OpponentDeckName) : query.OrderByDescending(m => m.OpponentDeckName);
                break;
            case MatchupSortColumn.Plays:
                query = isAscending ? query.OrderBy(m => m.Plays) : query.OrderByDescending(m => m.Plays);
                break;
            case MatchupSortColumn.Wins:
                query = isAscending ? query.OrderBy(m => m.Wins) : query.OrderByDescending(m => m.Wins);
                break;
            case MatchupSortColumn.Losses:
                query = isAscending ? query.OrderBy(m => m.Losses) : query.OrderByDescending(m => m.Losses);
                break;
            case MatchupSortColumn.WinRate:
                query = isAscending ? query.OrderBy(m => m.WinRate) : query.OrderByDescending(m => m.WinRate);
                break;
        }
        return query;
    }

    private IEnumerable<PlayerStats> GetSortedPlayerStats()
    {
        IEnumerable<PlayerStats> query = playerStats;
        switch (currentPlayerSortColumn)
        {
            case PlayerSortColumn.Player:
                query = isPlayerSortAscending ? query.OrderBy(p => p.PlayerName) : query.OrderByDescending(p => p.PlayerName);
                break;
            case PlayerSortColumn.Plays:
                query = isPlayerSortAscending ? query.OrderBy(p => p.Plays) : query.OrderByDescending(p => p.Plays);
                break;
            case PlayerSortColumn.Wins:
                query = isPlayerSortAscending ? query.OrderBy(p => p.Wins) : query.OrderByDescending(p => p.Wins);
                break;
            case PlayerSortColumn.Losses:
                query = isPlayerSortAscending ? query.OrderBy(p => p.Losses) : query.OrderByDescending(p => p.Losses);
                break;
            case PlayerSortColumn.WinRate:
                query = isPlayerSortAscending ? query.OrderBy(p => p.WinRate) : query.OrderByDescending(p => p.WinRate);
                break;
            case PlayerSortColumn.Duration:
                query = isPlayerSortAscending ? query.OrderBy(p => p.AverageDuration) : query.OrderByDescending(p => p.AverageDuration);
                break;
        }
        return query;
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadDeckData();
    }

    private class DeckStats
    {
        public string DeckName { get; set; } = string.Empty;
        public int TotalPlays { get; set; }
        public int Wins { get; set; }
        public int Losses { get; set; }
        public double WinRate { get; set; }
    }

    private class MatchupStats
    {
        public string OpponentDeckName { get; set; } = string.Empty;
        public string OpponentLinkDeck { get; set; } = string.Empty;
        public List<DeckColorSymbol> OpponentColorSymbols { get; set; } = new();
        public int Plays { get; set; }
        public int Wins { get; set; }
        public int Losses { get; set; }
        public double WinRate { get; set; }
    }

    public class FirstPlayerStats
    {
        public string Result { get; set; } = string.Empty;
        public int Count { get; set; }
    }

    private class PlayerStats
    {
        public int PlayerId { get; set; }
        public string PlayerName { get; set; } = string.Empty;
        public int Plays { get; set; }
        public int Wins { get; set; }
        public int Losses { get; set; }
        public double WinRate { get; set; }
        public double AverageDuration { get; set; }
    }

    private record MatchedColorScore(Play Play, PlayerScore Score, IReadOnlyList<string> ColorIdentityKeys);
