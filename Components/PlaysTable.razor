@using MagicDraftStats.Models
@using MagicDraftStats.Services

@if (Plays == null || !Plays.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No plays data available. Count: @(Plays?.Count ?? 0)
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th style="white-space: nowrap;">Date</th>
                    <th>Duration</th>
                    <th class="flag-icon-column"></th>
                    <th>Winner</th>
                    <th></th>
                    <th class="flag-icon-column"></th>
                    <th>Loser</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var play in Plays)
                {
                    var winner = play.PlayerScores.FirstOrDefault(p => p.IsWinner);
                    var loser = play.PlayerScores.FirstOrDefault(p => !p.IsWinner);
                    
                    <tr>
                        <td style="white-space: nowrap;">@DateTime.Parse(play.Date).ToString("yyyy-MM-dd")</td>
                        <td>@(play.DurationInMinutes > 0 ? $"{play.DurationInMinutes} min" : "-")</td>
                        <td class="flag-icon-column">
                            @if (winner?.IsFirstPlayer == true)
                            {
                                <i class="bi bi-flag-fill text-warning" title="First Player"></i>
                            }
                        </td>
                        <td>
                            @if (winner != null)
                            {
                                <NavLink class="@($"player-link text-success {GetPlayerWeightClass(play, winner)}")" href="@Utilities.GetPlayerUrl(winner.PlayerRefId)">@winner.PlayerName</NavLink>
                            }
                            else
                            {
                                <span class="text-muted">No winner</span>
                            }
                        </td>
                        <td>
                            @if (winner != null)
                            {
                                var winnerColorSymbols = ColorIdentityHelper.GetRoleColorSymbols(winner.Deck);

                                @if (winnerColorSymbols.Count > 0)
                                {
                                    <div class="d-flex align-items-center gap-1" style="min-width: fit-content;">
                                        @foreach (var symbol in winnerColorSymbols)
                                        {
                                            <ColorChip ColorKey="@symbol.ColorKey" />
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="flag-icon-column">
                            @if (loser?.IsFirstPlayer == true)
                            {
                                <i class="bi bi-flag-fill text-warning" title="First Player"></i>
                            }
                        </td>
                        <td>
                            @if (loser != null)
                            {
                                <NavLink class="@($"player-link text-danger {GetPlayerWeightClass(play, loser)}")" href="@Utilities.GetPlayerUrl(loser.PlayerRefId)">@loser.PlayerName</NavLink>
                            }
                            else
                            {
                                <span class="text-muted">No loser</span>
                            }
                        </td>
                        <td>
                            @if (loser != null)
                            {
                                var loserColorSymbols = ColorIdentityHelper.GetRoleColorSymbols(loser.Deck);

                                @if (loserColorSymbols.Count > 0)
                                {
                                    <div class="d-flex align-items-center gap-1" style="min-width: fit-content;">
                                        @foreach (var symbol in loserColorSymbols)
                                        {
                                            <ColorChip ColorKey="@symbol.ColorKey" />
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter]
    public List<Play> Plays { get; set; } = new();

    [Parameter]
    public ISet<string>? HighlightScoreKeys { get; set; }

    private string GetPlayerWeightClass(Play play, PlayerScore score)
    {
        if (HighlightScoreKeys != null)
        {
            return HighlightScoreKeys.Contains(BuildPlayScoreKey(play, score)) ? "fw-bold" : string.Empty;
        }

        return string.Empty;
    }

    private static string BuildPlayScoreKey(Play play, PlayerScore score)
    {
        return $"{play.Date}|{score.PlayerRefId}|{score.Deck.Trim()}";
    }

} 