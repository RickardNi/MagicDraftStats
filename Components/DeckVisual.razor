@using MagicDraftStats.Models
@using MagicDraftStats.Services
@inject IScryfallCardService ScryfallCardService

@if (Cards == null || !Cards.Any())
{
    <div class="alert alert-info mb-0">No card data found for this deck.</div>
}
else if (isLoading)
{
    <div class="alert alert-info mb-0">
        <i class="bi bi-arrow-clockwise spin me-2"></i>Loading card images...
    </div>
}
else if (errorMessage != null)
{
    <div class="alert alert-warning mb-0">
        <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
    </div>
}
else
{
    @if (!areImagesReady)
    {
        <div class="alert alert-info mb-2">
            <i class="bi bi-arrow-clockwise spin me-2"></i>Loading card images...
        </div>
    }

    <div class="deck-visual-columns d-flex align-items-start gap-3 flex-nowrap pb-2 @(areImagesReady ? string.Empty : "deck-visual-preload")">
        @foreach (var pile in manaPiles)
        {
            <div class="deck-visual-column d-flex flex-column">
                @if (!IsSideboard)
                {
                    <h6 class="fw-bold mb-2 text-center">
                        @if (pile.IsLands)
                        {
                            <span>Lands</span>
                        }
                        else
                        {
                            <span>@pile.Label</span>
                        }
                    </h6>
                }

                @if (pile.PrimaryCards.Any())
                {
                    @if (IsSideboard || pile.IsLands)
                    {
                        <div class="card-stack mb-3">
                            @foreach (var card in ExpandCards(pile.PrimaryCards))
                            {
                                @RenderStackCard(card)
                            }
                        </div>
                    }
                    else
                    {
                        <div class="primary-stack-slot" style="@GetPrimarySlotStyle()">
                            <div class="card-stack mb-3">
                                @foreach (var card in ExpandCards(pile.PrimaryCards))
                                {
                                    @RenderStackCard(card)
                                }
                            </div>
                        </div>
                    }
                }
                else if (!IsSideboard && !pile.IsLands)
                {
                    <div class="primary-stack-slot" style="@GetPrimarySlotStyle()"></div>
                }

                @if (!IsSideboard && pile.SecondaryCards.Any())
                {
                    <div class="card-stack">
                        @foreach (var card in ExpandCards(pile.SecondaryCards))
                        {
                            @RenderStackCard(card)
                        }
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public List<CardEntry> Cards { get; set; } = new();

    [Parameter]
    public bool IsSideboard { get; set; }

    private bool isLoading = true;
    private string? errorMessage;
    private List<ManaPile> manaPiles = new();
    private int maxPrimaryStackCount = 0;
    private int totalImageCount = 0;
    private int loadedImageCount = 0;
    private bool areImagesReady = false;

    protected override async Task OnParametersSetAsync()
    {
        await LoadVisuals();
    }

    private async Task LoadVisuals()
    {
        if (Cards == null || !Cards.Any())
        {
            manaPiles = new();
            maxPrimaryStackCount = 0;
            totalImageCount = 0;
            loadedImageCount = 0;
            areImagesReady = true;
            isLoading = false;
            errorMessage = null;
            return;
        }

        try
        {
            isLoading = true;
            errorMessage = null;
            areImagesReady = false;
            totalImageCount = 0;
            loadedImageCount = 0;
            manaPiles = new();
            maxPrimaryStackCount = 0;

            await InvokeAsync(StateHasChanged);

            var visuals = await ScryfallCardService.GetDeckCardVisualsAsync(Cards, "fdn");

            manaPiles = IsSideboard
                ? BuildSideboardPiles(visuals)
                : BuildDeckPiles(visuals);

            maxPrimaryStackCount = IsSideboard
                ? 0
                : manaPiles
                    .Where(pile => !pile.IsLands)
                    .Select(pile => ExpandCards(pile.PrimaryCards).Count())
                    .DefaultIfEmpty(0)
                    .Max();

            totalImageCount = manaPiles
                .Sum(pile => ExpandCards(pile.PrimaryCards).Count() + ExpandCards(pile.SecondaryCards).Count());
            loadedImageCount = 0;
            areImagesReady = totalImageCount == 0;
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not load card visuals: {ex.Message}";
            manaPiles = new();
            maxPrimaryStackCount = 0;
            totalImageCount = 0;
            loadedImageCount = 0;
            areImagesReady = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private Task OnCardImageLoaded()
    {
        if (areImagesReady || totalImageCount <= 0)
        {
            return Task.CompletedTask;
        }

        loadedImageCount++;
        if (loadedImageCount >= totalImageCount)
        {
            areImagesReady = true;
            return InvokeAsync(StateHasChanged);
        }

        return Task.CompletedTask;
    }

    private RenderFragment<DeckCardVisual> RenderStackCard => card => @<div class="stack-card" data-preview-url="@card.ImageUrl" data-preview-alt="@card.Name" onmouseenter="DeckVisualTooltip.show(event, this)" onmousemove="DeckVisualTooltip.move(event, this)" onmouseleave="DeckVisualTooltip.hide()">
        @if (!string.IsNullOrWhiteSpace(card.ScryfallUrl))
        {
            <a href="@card.ScryfallUrl" target="_blank" rel="noopener" class="text-decoration-none d-block">
                <img src="@card.ImageUrl" alt="@card.Name" class="img-fluid rounded-3 shadow-sm" loading="eager" @onload="OnCardImageLoaded" @onerror="OnCardImageLoaded" />
            </a>
        }
        else
        {
            <img src="@card.ImageUrl" alt="@card.Name" class="img-fluid rounded-3 shadow-sm" loading="eager" @onload="OnCardImageLoaded" @onerror="OnCardImageLoaded" />
        }
    </div>;

    private static int GetManaBucket(int? manaValue)
    {
        if (!manaValue.HasValue)
        {
            return int.MaxValue;
        }

        var mana = Math.Max(0, manaValue.Value);
        return mana >= 6 ? 6 : mana;
    }

    private static int GetManaSortValue(int? manaValue)
    {
        return manaValue ?? int.MaxValue;
    }

    private static List<ManaPile> BuildDeckPiles(List<DeckCardVisual> visuals)
    {
        var nonLands = visuals.Where(card => !card.IsLand).ToList();
        var lands = visuals.Where(card => card.IsLand).ToList();

        var groupedNonLands = nonLands
            .GroupBy(card => GetManaBucket(card.ManaValue))
            .OrderBy(group => group.Key)
            .Select(group => new ManaPile
            {
                Label = group.Key == int.MaxValue ? "?" : (group.Key == 6 ? "6+" : group.Key.ToString()),
                IsLands = false,
                PrimaryCards = group
                    .Where(card => card.IsCreature || card.IsPlaneswalker)
                    .OrderBy(card => GetManaSortValue(card.ManaValue))
                    .ThenBy(card => card.Name)
                    .ToList(),
                SecondaryCards = group
                    .Where(card => !card.IsCreature && !card.IsPlaneswalker)
                    .OrderBy(card => GetManaSortValue(card.ManaValue))
                    .ThenBy(card => card.Name)
                    .ToList()
            })
            .ToList();

        if (lands.Any())
        {
            groupedNonLands.Add(new ManaPile
            {
                Label = "Lands",
                IsLands = true,
                PrimaryCards = lands
                    .OrderByDescending(card => card.IsBasicLand)
                    .ThenBy(card => card.Name)
                    .ToList(),
                SecondaryCards = new List<DeckCardVisual>()
            });
        }

        return groupedNonLands;
    }

    private static List<ManaPile> BuildSideboardPiles(List<DeckCardVisual> visuals)
    {
        var creatureAndPlaneswalkerCards = visuals
            .Where(card => card.IsCreature || card.IsPlaneswalker)
            .OrderBy(card => GetManaSortValue(card.ManaValue))
            .ThenBy(card => card.Name)
            .ToList();

        var otherSpellCards = visuals
            .Where(card => !card.IsLand && !card.IsCreature && !card.IsPlaneswalker)
            .OrderBy(card => GetManaSortValue(card.ManaValue))
            .ThenBy(card => card.Name)
            .ToList();

        var landCards = visuals
            .Where(card => card.IsLand)
            .OrderBy(card => GetManaSortValue(card.ManaValue))
            .ThenBy(card => card.Name)
            .ToList();

        var piles = new List<ManaPile>();

        if (creatureAndPlaneswalkerCards.Any())
        {
            piles.Add(new ManaPile
            {
                Label = string.Empty,
                IsLands = false,
                PrimaryCards = creatureAndPlaneswalkerCards,
                SecondaryCards = new List<DeckCardVisual>()
            });
        }

        if (otherSpellCards.Any())
        {
            piles.Add(new ManaPile
            {
                Label = string.Empty,
                IsLands = false,
                PrimaryCards = otherSpellCards,
                SecondaryCards = new List<DeckCardVisual>()
            });
        }

        if (landCards.Any())
        {
            piles.Add(new ManaPile
            {
                Label = string.Empty,
                IsLands = true,
                PrimaryCards = landCards,
                SecondaryCards = new List<DeckCardVisual>()
            });
        }

        return piles;
    }

    private string GetPrimarySlotStyle()
    {
        const int firstCardHeight = 235;
        const int revealStep = 24;
        const int interStackGap = 20;

        if (maxPrimaryStackCount <= 0)
        {
            return "height: 0;";
        }

        var slotHeight = firstCardHeight + ((maxPrimaryStackCount - 1) * revealStep) + interStackGap;
        return $"height: {slotHeight}px;";
    }

    private static IEnumerable<DeckCardVisual> ExpandCards(IEnumerable<DeckCardVisual> cards)
    {
        foreach (var card in cards)
        {
            for (var countIndex = 0; countIndex < card.Count; countIndex++)
            {
                yield return card;
            }
        }
    }

    private class ManaPile
    {
        public string Label { get; set; } = string.Empty;
        public bool IsLands { get; set; }
        public List<DeckCardVisual> PrimaryCards { get; set; } = new();
        public List<DeckCardVisual> SecondaryCards { get; set; } = new();
    }
}
