@using MagicDraftStats.Models
@using MagicDraftStats.Services
@inject NavigationManager NavigationManager

@if (DeckRows == null || DeckRows.Count == 0)
{
    <div class="alert alert-warning mb-0">
        <i class="bi bi-exclamation-triangle me-2"></i>@EmptyMessage
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>
                        <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(SortColumn.DeckName)">
                            Deck
                            @if (currentSortColumn == SortColumn.DeckName)
                            {
                                <i class="bi @(isAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                            }
                            else
                            {
                                <i class="bi bi-sort text-muted"></i>
                            }
                        </button>
                    </th>
                    <th></th>
                    <th>
                        <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(SortColumn.PlayerName)">
                            Player
                            @if (currentSortColumn == SortColumn.PlayerName)
                            {
                                <i class="bi @(isAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                            }
                            else
                            {
                                <i class="bi bi-sort text-muted"></i>
                            }
                        </button>
                    </th>
                    <th>
                        <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(SortColumn.Date)">
                            Date
                            @if (currentSortColumn == SortColumn.Date)
                            {
                                <i class="bi @(isAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                            }
                            else
                            {
                                <i class="bi bi-sort text-muted"></i>
                            }
                        </button>
                    </th>
                    <th class="text-center">
                        <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(SortColumn.Rank)">
                            Rank
                            @if (currentSortColumn == SortColumn.Rank)
                            {
                                <i class="bi @(isAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                            }
                            else
                            {
                                <i class="bi bi-sort text-muted"></i>
                            }
                        </button>
                    </th>
                    <th class="text-center">
                        <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(SortColumn.Plays)">
                            Plays
                            @if (currentSortColumn == SortColumn.Plays)
                            {
                                <i class="bi @(isAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                            }
                            else
                            {
                                <i class="bi bi-sort text-muted"></i>
                            }
                        </button>
                    </th>
                    <th class="text-center">
                        <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(SortColumn.Wins)">
                            Wins
                            @if (currentSortColumn == SortColumn.Wins)
                            {
                                <i class="bi @(isAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                            }
                            else
                            {
                                <i class="bi bi-sort text-muted"></i>
                            }
                        </button>
                    </th>
                    <th class="text-center">
                        <button class="btn btn-link text-decoration-none p-0 fw-bold" @onclick="() => SortBy(SortColumn.Losses)">
                            Losses
                            @if (currentSortColumn == SortColumn.Losses)
                            {
                                <i class="bi @(isAscending ? "bi-sort-up" : "bi-sort-down")"></i>
                            }
                            else
                            {
                                <i class="bi bi-sort text-muted"></i>
                            }
                        </button>
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var deck in GetSortedDeckRows())
                {
                    <tr style="cursor: pointer;" @onclick="() => OpenDeck(deck.DeckId)">
                        <td>
                            <NavLink class="deck-link" href="@($"deck/{Uri.EscapeDataString(deck.DeckId)}")" @onclick:stopPropagation="true">@deck.DeckName</NavLink>
                        </td>
                        <td>
                            @if (deck.ColorSymbols.Count > 0)
                            {
                                <div class="d-flex align-items-center gap-1" style="min-width: fit-content;">
                                    @foreach (var symbol in deck.ColorSymbols)
                                    {
                                        <ColorChip ColorKey="@symbol.ColorKey" IsSplash="@symbol.IsSplash" />
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @if (deck.PlayerId > 0)
                            {
                                <NavLink class="deck-link" href="@Utilities.GetPlayerUrl(deck.PlayerId)" @onclick:stopPropagation="true">@deck.PlayerName</NavLink>
                            }
                            else
                            {
                                @deck.PlayerName
                            }
                        </td>
                        <td>
                            @if (deck.Date.HasValue)
                            {
                                <span style="white-space: nowrap;">@deck.Date.Value.ToString("yyyy-MM-dd")</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="text-center">
                            <span class="fw-bold @(deck.Rank == 1 ? "text-success-dark" : "text-warning")">@deck.Rank / @deck.PlayerCount</span>
                        </td>
                        <td class="text-center">@deck.Plays</td>
                        <td class="text-center"><span class="text-success fw-bold">@deck.Wins</span></td>
                        <td class="text-center"><span class="text-danger">@deck.Losses</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter]
    public IReadOnlyList<DeckTableRow> DeckRows { get; set; } = [];

    [Parameter]
    public string EmptyMessage { get; set; } = "No decks found.";

    private SortColumn currentSortColumn = SortColumn.Date;
    private bool isAscending;

    private enum SortColumn
    {
        DeckName,
        PlayerName,
        Date,
        Rank,
        Plays,
        Wins,
        Losses
    }

    private void OpenDeck(string deckId)
    {
        NavigationManager.NavigateTo($"deck/{Uri.EscapeDataString(deckId)}");
    }

    private void SortBy(SortColumn column)
    {
        if (currentSortColumn == column)
        {
            isAscending = !isAscending;
        }
        else
        {
            currentSortColumn = column;
            isAscending = false;
        }
    }

    private IEnumerable<DeckTableRow> GetSortedDeckRows()
    {
        var query = currentSortColumn switch
        {
            SortColumn.DeckName => isAscending
                ? DeckRows.OrderBy(deck => deck.DeckName)
                : DeckRows.OrderByDescending(deck => deck.DeckName),
            SortColumn.PlayerName => isAscending
                ? DeckRows.OrderBy(deck => deck.PlayerName)
                : DeckRows.OrderByDescending(deck => deck.PlayerName),
            SortColumn.Date => isAscending
                ? DeckRows.OrderBy(deck => deck.Date)
                : DeckRows.OrderByDescending(deck => deck.Date),
            SortColumn.Rank => isAscending
                ? DeckRows.OrderBy(deck => deck.Rank)
                : DeckRows.OrderByDescending(deck => deck.Rank),
            SortColumn.Plays => isAscending
                ? DeckRows.OrderBy(deck => deck.Plays)
                : DeckRows.OrderByDescending(deck => deck.Plays),
            SortColumn.Wins => isAscending
                ? DeckRows.OrderBy(deck => deck.Wins)
                : DeckRows.OrderByDescending(deck => deck.Wins),
            SortColumn.Losses => isAscending
                ? DeckRows.OrderBy(deck => deck.Losses)
                : DeckRows.OrderByDescending(deck => deck.Losses),
            _ => DeckRows.OrderByDescending(deck => deck.Date)
        };

        return query
            .ThenByDescending(deck => deck.Date)
            .ThenByDescending(deck => deck.Wins)
            .ThenBy(deck => deck.PlayerName);
    }
}